{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://constructor-studio.dev/schemas/map.schema.json",
  "title": "cfs map output",
  "type": "object",
  "required": ["version", "generated_at", "workspace", "scan", "nodes", "edges", "dangling_cpt_uses", "categories"],
  "properties": {
    "version": { "const": "1.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "workspace": {
      "type": "object",
      "required": ["primary", "sources"],
      "properties": {
        "primary": { "type": "string" },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "path", "reachable", "role"],
            "properties": {
              "name": { "type": "string" },
              "path": { "type": "string" },
              "reachable": { "type": "boolean" },
              "role": { "type": "string", "enum": ["artifacts", "codebase", "kits", "full"] }
            }
          }
        }
      }
    },
    "scan": {
      "type": "object",
      "required": ["artifacts_toml", "systems_scanned", "systems_docs_only", "skip_dirs"],
      "properties": {
        "artifacts_toml": { "type": ["string", "null"] },
        "systems_scanned": { "type": "integer", "minimum": 0 },
        "systems_docs_only": { "type": "integer", "minimum": 0 },
        "skip_dirs": { "type": "array", "items": { "type": "string" } }
      }
    },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "rel_path", "source", "kind", "language", "category", "category_origin", "content", "loc", "cpt_defs", "cpt_uses"],
        "properties": {
          "id": { "type": "string" },
          "rel_path": { "type": ["string", "null"] },
          "source": { "type": ["string", "null"] },
          "kind": { "enum": ["markdown", "source", "phantom-cpt"] },
          "language": { "type": ["string", "null"] },
          "category": { "type": "string" },
          "category_origin": { "enum": ["override", "registry", "parent-dir", "phantom"] },
          "content": { "type": ["string", "null"] },
          "loc": { "type": "integer", "minimum": 0 },
          "cpt_defs": { "type": "array", "items": { "type": "string" } },
          "cpt_uses": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["cpt_id", "line", "snippet", "marker_kind"],
              "properties": {
                "cpt_id": { "type": "string" },
                "line": { "type": "integer", "minimum": 1 },
                "snippet": { "type": "string" },
                "marker_kind": { "enum": ["scope", "block-begin", "block-end", "md-ref", "md-def"] }
              }
            }
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "type", "refs", "cross_repo", "dangling"],
        "properties": {
          "id": { "type": "string" },
          "from": { "type": "string" },
          "to": { "type": "string" },
          "type": { "enum": ["file-link", "cpt-doc", "cpt-impl"] },
          "cross_repo": { "type": "boolean" },
          "dangling": { "type": "boolean" },
          "refs": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["cpt_id", "line", "snippet", "def_line", "def_snippet"],
              "properties": {
                "cpt_id": { "type": ["string", "null"] },
                "line": { "type": "integer", "minimum": 1 },
                "snippet": { "type": "string" },
                "def_line": { "type": ["integer", "null"] },
                "def_snippet": { "type": ["string", "null"] }
              }
            }
          }
        }
      }
    },
    "dangling_cpt_uses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cpt_id", "node_id", "line", "snippet"],
        "properties": {
          "cpt_id": { "type": "string" },
          "node_id": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 },
          "snippet": { "type": "string" }
        }
      }
    },
    "categories": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["node_count", "origin_counts", "style"],
        "properties": {
          "node_count": { "type": "integer", "minimum": 0 },
          "origin_counts": {
            "type": "object",
            "properties": {
              "override": { "type": "integer", "minimum": 0 },
              "registry": { "type": "integer", "minimum": 0 },
              "parent-dir": { "type": "integer", "minimum": 0 },
              "phantom": { "type": "integer", "minimum": 0 }
            }
          },
          "style": {
            "type": "object",
            "required": ["color", "background"],
            "properties": {
              "color": { "type": "string" },
              "background": { "type": "string" }
            }
          }
        }
      }
    },
    "layout": {
      "type": "object",
      "properties": {
        "vis_nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "x", "y"],
            "properties": {
              "id": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "label": { "type": "string" },
              "shape": { "type": "string" },
              "category": { "type": "string" },
              "group": { "type": "string" }
            }
          }
        },
        "bucket_rects": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["id", "x", "y", "w", "h", "label"],
            "properties": {
              "id": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "w": { "type": "number" },
              "h": { "type": "number" },
              "label": { "type": "string" }
            }
          }
        },
        "category_bands": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["x", "y", "w", "h", "label"],
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "w": { "type": "number" },
              "h": { "type": "number" },
              "label": { "type": "string" },
              "fill": { "type": "string" },
              "stroke": { "type": "string" },
              "title_color": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
